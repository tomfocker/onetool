{
  "name": "onetool",
  "version": "1.0.0",
  "description": "高颜值本地小工具箱",
  "main": "./out/main/index.js",
  "author": "八骏马",
  "license": "MIT",
  "homepage": "https://space.bilibili.com/35149135",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomfocker/onetool.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "test": "node --test \"src/**/*.test.cjs\"",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:ntfs-fast-scan": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-ntfs-fast-scan.ps1",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build:ntfs-fast-scan && npm run build && electron-builder --dir",
    "build:win": "npm run build:ntfs-fast-scan && npm run build && electron-builder --win",
    "release:win": "npm run build:ntfs-fast-scan && npm run build && electron-builder --win nsis portable --publish never",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-window-state": "^5.0.3",
    "electron-updater": "^6.7.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.468.0",
    "node-global-key-listener": "^0.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-image-crop": "^11.0.10",
    "tailwind-merge": "^2.5.5",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.onetool",
    "productName": "onetool",
    "copyright": "Copyright © 2025 八骏马",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "!release/**/*",
      "!release_new/**/*"
    ],
    "directories": {
      "output": "release_new"
    },
    "publish": {
      "provider": "github",
      "owner": "tomfocker",
      "repo": "onetool"
    },
    "extraResources": [
      {
        "from": "resources/FlipIt.scr",
        "to": "FlipIt.scr"
      },
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/model-download",
        "to": "model-download"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png",
      "extraResources": [
        {
          "from": "resources/space-scan/ntfs-fast-scan.exe",
          "to": "space-scan/ntfs-fast-scan.exe"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
